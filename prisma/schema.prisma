// Prisma Schema Spec - Multi-Tenant FieldTracker SaaS
//
// To apply this schema in production, run:
//   npx prisma db push
//   npx prisma generate

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Plan {
  FREE_TRIAL
  BASIC
  PREMIUM
  ENTERPRISE
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
}

enum AnnouncementType {
  info
  warning
  alert
  maintenance
}

model SuperAdmin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("superadmin")
  createdAt    DateTime @default(now())
}

model Organization {
  id               String       @id @default(uuid())
  companyName      String
  adminEmail       String       @unique
  passwordHash     String
  phone            String
  industry         String
  createdAt        DateTime     @default(now())
  subscriptionPlan Plan         @default(FREE_TRIAL)
  employeeLimit    Int          @default(5)
  status           OrgStatus    @default(ACTIVE)
  
  // Relations
  employees        Employee[]
  subscription     Subscription?
  tasks            Task[]
}

model Subscription {
  id               String       @id @default(uuid())
  organizationId   String       @unique
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan             Plan         @default(FREE_TRIAL)
  expiryDate       DateTime
  paymentStatus    String       @default("PAID")
  storageLimit     Int          @default(5) // in GB
  gpsLimitHours    Int          @default(24) // daily gps log lifetime
  updatedAt        DateTime     @updatedAt
}

model Employee {
  id             String       @id @default(uuid())
  name           String
  email          String       @unique
  passwordHash   String
  role           String
  department     String
  phone          String
  avatar         String?
  color          String       @default("#3b82f6")
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime     @default(now())
}

model Announcement {
  id        String           @id @default(uuid())
  title     String
  message   String
  type      AnnouncementType @default(info)
  createdAt DateTime         @default(now())
}

model Task {
  id             String       @id @default(uuid())
  title          String
  description    String?
  status         String       @default("PENDING")
  latitude       Float
  longitude      Float
  address        String?
  createdAt      DateTime     @default(now())
  completedAt    DateTime?
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
